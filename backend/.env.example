# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/LomaX?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SMTP Email (Gmail example) ──────────────────────────────────────────────
# Leave blank to use file-logger fallback in development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_16chars
SMTP_FROM_NAME=LomaX Banking

# ─── Frontend URL (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=https://your-app.netlify.app
